<!DOCTYPE html>
<html>
<head>
  <title>Weather App</title>

  <style>
    body {
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #4facfe, #00c6ff);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0;
    }

    .container {
      background: white;
      padding: 45px 40px;
      border-radius: 16px;
      width: 380px;
      text-align: center;
      box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    h1 {
      margin-bottom: 8px;
      color: #222;
      font-size: 30px;
      letter-spacing: 1px;
    }

    .location {
      font-size: 20px;
      color: #555;
      margin-bottom: 25px;
      font-weight: 500;
    }

    .weather-box {
      padding: 22px;
      border-radius: 12px;
      background: #f8f9fb;
      text-align: left;
      margin-bottom: 25px;
    }

    .weather-row {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #e4e4e4;
      font-size: 15px;
    }

    .weather-row:last-child {
      border-bottom: none;
    }

    .label {
      font-weight: 600;
      color: #333;
    }

    .value {
      color: #555;
    }

    form {
      margin-top: 10px;
    }

    input {
      width: 100%;
      padding: 11px;
      border-radius: 8px;
      border: 1px solid #ccc;
      font-size: 14px;
      margin-bottom: 12px;
      outline: none;
      transition: border 0.2s;
    }

    input:focus {
      border-color: #4facfe;
    }

    button {
      width: 100%;
      padding: 11px;
      border-radius: 8px;
      border: none;
      background: linear-gradient(135deg, #4facfe, #00c6ff);
      color: white;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.1s;
    }

    button:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

  </style>

</head>

<body>

<div class="container">

    <h1>Weather App</h1>

    <% if(error) { %>
      <p style="color:red; font-weight:bold; margin-bottom:15px;">
        <%= error %>
      </p>
    <% } %>
    
    <% if(city) { %>
    
    <div class="location">
      <%= city %>
    </div>
    
    <div class="weather-box">
    
      <div class="weather-row">
        <span class="label">Temperature</span>
        <span><%= temp %> °C</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Feels Like</span>
        <span><%= feels_like %> °C</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Wind Speed</span>
        <span><%= wind %> m/s</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Wind Direction</span>
        <span><%= direction %>°</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Humidity</span>
        <span><%= humidity %> %</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Cloud Coverage</span>
        <span><%= clouds %> %</span>
      </div>
    
      <div class="weather-row">
        <span class="label">Pressure</span>
        <span><%= pressure %> hPa</span>
      </div>
    
    </div>
    
    <% } %>

<form action="/weather" method="POST">

  <input 
    type="text" 
    name="city" 
    placeholder="Enter city name"
    required
  />

  <button type="submit">Get Weather</button>

</form>

</div>

</body>
</html>